# ─────────────────────────────────────────────────────────────
# Integration test environment — DO NOT USE IN PRODUCTION
# Load with: node --env-file=.env.test ./src/routes/tenant-isolation.integration.test.ts
# or via dotenv: import 'dotenv/config' (already in test files)
# ─────────────────────────────────────────────────────────────

# Backend server
TEST_BASE_URL=http://127.0.0.1:4000

# Primary tenant credentials (company-demo-001)
TEST_ADMIN_EMAIL=admin@siamtech.co.th
TEST_ACCOUNTANT_EMAIL=accountant@siamtech.co.th
TEST_ADMIN_PASSWORD=Admin@123456
TEST_ACCOUNTANT_PASSWORD=Account@123456

# Secondary tenant credentials (company-demo-002) — seeded for RLS tests
TEST_SECONDARY_ADMIN_EMAIL=admin+1@demo-etax.co.th

# Domain split E2E tests
TEST_APEX_ORIGIN=http://localhost:3000
TEST_APP_ORIGIN=http://app.localhost:3000
TEST_OPS_ORIGIN=http://ops.localhost:3000

# Certificate for XAdES-BES signing (tests use sandbox/mock RD, cert may not be needed)
CERT_PATH=./certs/test-company.p12
CERT_PASSWORD=etax-dev-password

# Redis (required for BullMQ queues)
REDIS_URL=redis://:redis_secret@localhost:6379