// Prisma schema for e-Tax Invoice System
// Bilingual support: all user-facing string fields have _th and _en variants

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  accountant
  viewer
}

enum InvoiceType {
  tax_invoice
  tax_invoice_receipt
  receipt
  credit_note
  debit_note
}

enum InvoiceStatus {
  draft
  pending
  approved
  submitted
  rejected
  cancelled
}

enum RDSubmissionStatus {
  pending
  in_progress
  success
  failed
  retrying
}

enum VatType {
  vat7
  vatExempt
  vatZero
}

enum QuotationStatus {
  draft // ยังไม่ส่ง — แก้ได้
  sent // ส่งให้ลูกค้าแล้ว
  accepted // ลูกค้ายืนยัน — รอแปลงเป็นใบกำกับภาษี
  converted // แปลงเป็น Invoice แล้ว
  rejected // ลูกค้าปฏิเสธ
  expired // เลยวัน validUntil
  cancelled // ยกเลิกฝั่งผู้ขาย
}

enum DeliveryNoteStatus {
  draft // ยังไม่ออกเอกสาร — แก้ได้
  issued // ออกเอกสารแล้ว
  delivered // ส่งของครบแล้ว
  converted // แปลง/ผูกกับ Invoice แล้ว
  cancelled // ยกเลิกฝั่งผู้ขาย
}

enum RecurringInvoiceStatus {
  active
  paused
  ended
  cancelled
}

enum RecurringInvoiceFrequency {
  weekly
  monthly
  quarterly
  yearly
}

enum BillingPlan {
  starter
  business
  enterprise
}

enum BillingStatus {
  pending
  active
  past_due
  canceled
  incomplete
  incomplete_expired
  trialing
  unpaid
}

enum SignupStatus {
  pending
  paid
  activated
  expired
  failed
}

enum AttachmentFileType {
  image
  pdf
  link
}

enum EvidenceType {
  receipt
  chat
  map
  other
}

enum ExpenseVoucherStatus {
  draft
  submitted
  approved
  rejected
}

enum ProjectStatus {
  active
  on_hold
  completed
  archived
}

enum ProjectMemberRole {
  owner
  approver
  member
  viewer
}

model Company {
  id           String  @id @default(cuid())
  nameTh       String
  nameEn       String?
  taxId        String  @unique
  branchCode   String  @default("00000")
  branchNameTh String?
  branchNameEn String?
  addressTh    String
  addressEn    String?
  phone        String?
  email        String?
  website      String?
  logoUrl      String?

  // Serialized certificate (encrypted)
  // certificateBlob: raw .p12 bytes — primary storage (per-company, survives deploys).
  // certificatePath: legacy file-path fallback — read only for the dev/global cert
  //                  loaded from process.env.CERT_PATH; never written by uploads anymore.
  // certificatePassword: encrypted via encryptConfigValue (see configEncryption.ts).
  certificateBlob       Bytes?
  certificateUploadedAt DateTime?
  certificatePath       String?
  certificatePassword   String?

  // Per-company "send-as" email domain. When verified, outbound emails
  // (POST /api/invoices/:id/send-email) use `noreply@<brandDomain>` as the
  // From address instead of the global SMTP_FROM_DEFAULT. Customer must
  // own the domain and add SPF/DKIM DNS records pointing at our SMTP
  // provider (Resend). brandDomainProviderId stores the provider-side
  // record id so we can re-check verification status without re-creating.
  brandDomain           String?
  brandDomainProviderId String?
  brandDomainStatus     String? // 'pending' | 'verified' | 'failed'
  brandDomainVerifiedAt DateTime?

  // RD Config
  rdClientId     String?
  rdClientSecret String?
  rdEnvironment  String  @default("sandbox")

  // Expense settings
  expenseLimit Decimal? @db.Decimal(12, 2)

  // Storage quota
  storageUsedBytes         BigInt    @default(0)
  storageQuotaBytes        BigInt    @default(524288000) // 500MB
  googleDriveOwnerUserId   String?
  googleDriveOwnerLinkedAt DateTime?

  // Company master workspace sheet (deduplicated)
  googleWorkspaceSheetId       String?
  googleWorkspaceSheetUrl      String?
  googleWorkspaceSheetSyncedAt DateTime?

  // OCR cost controls
  ocrMonthlyBudgetThb Decimal? @db.Decimal(10, 2)
  ocrUsageThisMonth   Decimal  @default(0) @db.Decimal(10, 2)

  // Line OA settings
  lineNotifyEnabled   Boolean @default(false)
  overdueReminderDays Int     @default(3)

  // Document issuing profile
  documentBankAccounts     Json?
  documentSignatureProfile Json?

  // PDPA Section 33 — erasure. Owner can request account deletion; we keep
  // tax records 5 years per Revenue Code but PII gets anonymised immediately.
  // hardDeletedAt = scheduled time the retentionLoop will purge everything.
  deletionRequestedAt   DateTime?
  deletionRequestedBy   String?
  hardDeleteScheduledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  customers             Customer[]
  products              Product[]
  stockMovements        StockMovement[]
  invoices              Invoice[]
  quotations            Quotation[]
  deliveryNotes         DeliveryNote[]
  recurringInvoices     RecurringInvoice[]
  subscription          CompanySubscription?
  billingTransactions   BillingTransaction[]
  purchaseInvoices      PurchaseInvoice[]
  projectPurchaseOrders ProjectPurchaseOrder[]
  projects              Project[]
  expenseVouchers       ExpenseVoucher[]
  pettyCash             PettyCash?
  lineGroupLinks        LineGroupLink[]
  whtCertificates       WhtCertificate[]
  employees             Employee[]
  payrollRuns           PayrollRun[]

  @@map("companies")
}

model User {
  id                  String    @id @default(cuid())
  companyId           String
  email               String    @unique
  name                String
  passwordHash        String?
  googleSub           String?   @unique
  role                UserRole  @default(viewer)
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  googleRefreshToken  String?
  googleDriveLinkedAt DateTime?

  // PDPA consent — captured at signup. Stores the legal-document version the
  // user accepted so we can show a re-consent prompt when terms change.
  legalAcceptedAt      DateTime?
  legalAcceptedVersion String?
  marketingOptInAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices           Invoice[]           @relation("CreatedBy")
  quotations         Quotation[]         @relation("QuotationCreatedBy")
  deliveryNotes      DeliveryNote[]      @relation("DeliveryNoteCreatedBy")
  recurringInvoices  RecurringInvoice[]  @relation("RecurringInvoiceCreatedBy")
  auditLogs          AuditLog[]
  fcmTokens          FcmToken[]
  purchaseInvoices   PurchaseInvoice[]   @relation("PurchaseCreatedBy")
  expenseVouchers    ExpenseVoucher[]    @relation("ExpenseVoucherCreatedBy")
  ownedProjects      Project[]           @relation("ProjectOwner")
  approvedProjects   Project[]           @relation("ProjectApprover")
  createdProjects    Project[]           @relation("ProjectCreatedBy")
  projectMembers     ProjectMember[]
  lineUserLink       LineUserLink?
  lineProjectMembers LineProjectMember[]
  linkedLineGroups   LineGroupLink[]     @relation("LineGroupLinkedBy")
  driveOAuthStates   DriveOAuthState[]

  @@index([companyId])
  // List active users per company (user management page)
  @@index([companyId, isActive])
  // Role-based filtering within a tenant (e.g., list all accountants)
  @@index([companyId, role])
  @@map("users")
}

model DriveOAuthState {
  id         String   @id @default(cuid())
  state      String   @unique
  userId     String
  companyId  String
  returnPath String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
  @@map("drive_oauth_states")
}

model Customer {
  id                 String   @id @default(cuid())
  companyId          String
  nameTh             String
  nameEn             String?
  taxId              String
  branchCode         String   @default("00000")
  branchNameTh       String?
  branchNameEn       String?
  addressTh          String
  addressEn          String?
  email              String?
  phone              String?
  contactPerson      String?
  creditLimit        Decimal? @db.Decimal(12, 2)
  creditDays         Int?
  personalId         String? // เลขประจำตัว 13 หลักสำหรับบุคคลธรรมดา
  partyRole          String   @default("customer") // customer | supplier | both
  customerKind       String   @default("company") // company | individual
  useCase            String   @default("general") // general | full_tax_invoice | credit | contract_project | vendor_payee
  verificationStatus String   @default("not_required") // not_required | missing | partial | complete
  vatEvidenceStatus  String   @default("not_required") // not_required | missing | uploaded | verified
  isActive           Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  quotations        Quotation[]
  deliveryNotes     DeliveryNote[]
  recurringInvoices RecurringInvoice[]
  documents         CustomerDocument[]

  @@unique([companyId, taxId, branchCode])
  @@index([companyId])
  @@index([companyId, verificationStatus])
  @@index([companyId, partyRole])
  @@index([companyId, useCase])
  // Customer list page always filters by isActive within a company
  @@index([companyId, isActive])
  @@map("customers")
}

model CustomerDocument {
  id             String    @id @default(cuid())
  companyId      String
  customerId     String
  uploadedById   String?
  documentType   String // company_registration | vat_certificate | contract | credit_agreement | director_id | personal_id | bank_account | other
  requiredFor    String    @default("general")
  status         String    @default("uploaded") // uploaded | verified | rejected
  fileName       String
  mimeType       String
  fileSize       Int
  // S3 is the system of record. Drive is an optional mirror so customers
  // who connect Google Drive can collaborate on their own files. If they
  // ever revoke OAuth or delete the Drive folder, S3 still has the file.
  s3Key          String?
  s3Url          String?
  driveFileId    String?
  driveUrl       String?
  driveFolderId  String?
  driveFolderUrl String?
  driveUserDrive Boolean   @default(false)
  sensitive      Boolean   @default(false)
  notes          String?
  uploadedAt     DateTime  @default(now())
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId, customerId])
  @@index([companyId, documentType])
  @@index([companyId, status])
  @@map("customer_documents")
}

model JuristicOpenDataCache {
  id           String  @id @default(cuid())
  taxId        String  @unique
  nameTh       String?
  nameEn       String?
  addressTh    String?
  status       String?
  juristicType String?
  source       String  @default("open-dbd")
  raw          Json?

  vatRegistered   Boolean   @default(false)
  vatName         String?
  vatAddress      String?
  vatSource       String?
  vatLastSyncedAt DateTime?

  lastSyncedAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([taxId])
  @@index([status])
  @@map("juristic_open_data_cache")
}

model DbdOpenDataSyncRun {
  id              String    @id @default(cuid())
  kind            String
  status          String
  source          String?
  recordsRead     Int       @default(0)
  recordsUpserted Int       @default(0)
  error           String?
  triggeredBy     String?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  @@index([kind, startedAt])
  @@index([status, startedAt])
  @@map("dbd_open_data_sync_runs")
}

model Product {
  id             String  @id @default(cuid())
  companyId      String
  code           String
  nameTh         String
  nameEn         String?
  descriptionTh  String?
  descriptionEn  String?
  unit           String
  unitPrice      Float
  vatType        VatType @default(vat7)
  productType    String  @default("product") @map("product_type")
  category       String?
  accountCode    String? @map("account_code")
  unitCost       Float?  @map("unit_cost")
  defaultWhtRate String? @map("default_wht_rate")
  internalNote   String? @map("internal_note")
  isActive       Boolean @default(true)

  // ── Inventory (opt-in per product) ─────────────────────────────────
  // Service-business tenants leave trackInventory false and never see
  // the inventory UI. Once flipped on, hooks on Invoice issue and
  // PurchaseInvoice create write StockMovement rows and keep
  // currentStock in sync.
  trackInventory Boolean @default(false) @map("track_inventory")
  currentStock   Float   @default(0) @map("current_stock")
  reorderPoint   Float?  @map("reorder_point")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceItems          InvoiceItem[]
  quotationItems        QuotationItem[]
  deliveryNoteItems     DeliveryNoteItem[]
  recurringInvoiceItems RecurringInvoiceItem[]
  stockMovements        StockMovement[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, productType])
  @@index([companyId, category])
  @@index([companyId, trackInventory])
  @@map("products")
}

// Stock ledger — one row per increment / decrement event. currentStock
// on Product is the running sum, but this table is the audit truth.
enum StockMovementType {
  sale // Invoice issued (auto)
  purchase // PurchaseInvoice created (auto)
  adjustment_in // Manual count fix (found more than expected)
  adjustment_out // Manual count fix (loss / damage / write-off)
  opening_balance // Initial stock when trackInventory is first enabled
}

model StockMovement {
  id        String            @id @default(cuid())
  companyId String
  productId String
  type      StockMovementType
  qty       Float // positive for IN, negative for OUT — caller writes the sign
  refType   String? // 'invoice' | 'purchase_invoice' | 'manual'
  refId     String?
  note      String?
  createdBy String?
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId, productId])
  @@index([companyId, createdAt])
  @@index([refType, refId])
  @@map("stock_movements")
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  projectId     String?
  invoiceNumber String
  type          InvoiceType
  status        InvoiceStatus @default(draft)
  language      String        @default("th")

  invoiceDate DateTime
  dueDate     DateTime?

  buyerId String
  seller  Json

  subtotal       Float
  vatAmount      Float
  discountAmount Float @default(0) @map("discount")
  total          Float

  // WHT (withholding tax)
  whtRate          String? @map("wht_rate")
  whtAmount        Float?  @map("wht_amount")
  whtCertificateId String? @map("wht_certificate_id")

  // Cancellation
  cancelledAt  DateTime? @map("cancelled_at")
  cancelledBy  String?   @map("cancelled_by")
  cancelReason String?   @map("cancel_reason")

  notes         String?
  paymentMethod String?

  // RD submission
  rdSubmissionStatus RDSubmissionStatus?
  rdDocId            String?
  rdSubmittedAt      DateTime?
  rdResponseXml      String?

  // Storage
  pdfUrl String?
  xmlUrl String?

  // Google Drive sync
  driveFileId    String?
  driveUrl       String?
  driveXmlFileId String?
  driveXmlUrl    String?

  // Reference (for credit/debit notes and receipts linked to a tax invoice)
  referenceDocNumber String?
  referenceInvoiceId String? // FK → Invoice (ใบอ้างอิงสำหรับ receipt/credit/debit)

  // Payment tracking
  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  paidAmount Float?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company               @relation(fields: [companyId], references: [id])
  project          Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  buyer            Customer              @relation(fields: [buyerId], references: [id])
  creator          User                  @relation("CreatedBy", fields: [createdBy], references: [id])
  items            InvoiceItem[]
  deliveryNotes    DeliveryNote[]
  referenceInvoice Invoice?              @relation("InvoiceReference", fields: [referenceInvoiceId], references: [id])
  relatedDocuments Invoice[]             @relation("InvoiceReference")
  payments         Payment[]
  whtCertificates  WhtCertificate[]
  recurringRuns    RecurringInvoiceRun[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, projectId])
  @@index([companyId, status])
  @@index([companyId, invoiceDate])
  // Compound index for dashboard: "issued invoices in date range" — covers status + date together
  @@index([companyId, status, invoiceDate])
  // RD submission queue filters on rdSubmissionStatus per company
  @@index([companyId, rdSubmissionStatus])
  // FK indexes — Postgres does not create these automatically
  @@index([buyerId])
  @@index([createdBy])
  @@index([referenceInvoiceId])
  @@map("invoices")
}

// ── Recurring Invoice (ใบแจ้งหนี้/ใบกำกับซ้ำอัตโนมัติ) ─────────────
// Stores a reusable invoice template. The worker creates draft invoices only;
// issuing/submitting to RD remains an explicit user action.
model RecurringInvoice {
  id          String                    @id @default(cuid())
  companyId   String
  projectId   String?
  customerId  String
  name        String
  status      RecurringInvoiceStatus    @default(active)
  frequency   RecurringInvoiceFrequency
  interval    Int                       @default(1)
  language    String                    @default("th")
  invoiceType InvoiceType               @default(tax_invoice)

  startDate   DateTime
  nextRunDate DateTime
  endDate     DateTime?
  dueDays     Int?
  maxRuns     Int?
  runCount    Int       @default(0)
  lastRunAt   DateTime?

  discountAmount Float   @default(0) @map("discount")
  notes          String?
  paymentMethod  String?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project  Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  customer Customer               @relation(fields: [customerId], references: [id])
  creator  User                   @relation("RecurringInvoiceCreatedBy", fields: [createdBy], references: [id])
  items    RecurringInvoiceItem[]
  runs     RecurringInvoiceRun[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, nextRunDate])
  @@index([customerId])
  @@index([createdBy])
  @@map("recurring_invoices")
}

model RecurringInvoiceItem {
  id                 String  @id @default(cuid())
  recurringInvoiceId String
  productId          String?
  nameTh             String
  nameEn             String?
  descriptionTh      String?
  descriptionEn      String?
  quantity           Float
  unit               String
  unitPrice          Float
  discountAmount     Float   @default(0) @map("discount")
  vatType            VatType @default(vat7)

  recurringInvoice RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
  product          Product?         @relation(fields: [productId], references: [id])

  @@index([recurringInvoiceId])
  @@map("recurring_invoice_items")
}

model RecurringInvoiceRun {
  id                 String   @id @default(cuid())
  recurringInvoiceId String
  companyId          String
  invoiceId          String?
  scheduledFor       DateTime
  generatedAt        DateTime @default(now())
  status             String   @default("generated")
  error              String?

  recurringInvoice RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
  invoice          Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@unique([recurringInvoiceId, scheduledFor])
  @@index([companyId, scheduledFor])
  @@index([invoiceId])
  @@map("recurring_invoice_runs")
}

model InvoiceItem {
  id             String  @id @default(cuid())
  invoiceId      String
  productId      String?
  nameTh         String
  nameEn         String?
  descriptionTh  String?
  descriptionEn  String?
  quantity       Float
  unit           String
  unitPrice      Float
  discountAmount Float   @default(0) @map("discount")
  vatType        VatType @default(vat7)
  amount         Float
  vatAmount      Float
  totalAmount    Float

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

// ── Quotation (ใบเสนอราคา) ───────────────────────────────────────────
// Pre-sale offer document. Not a tax document — no VAT obligation, no e-Tax
// submission. When the customer accepts, convert to an Invoice (sets
// convertedToInvoiceId pointing at the new Invoice row).
model Quotation {
  id              String          @id @default(cuid())
  companyId       String
  projectId       String?
  quotationNumber String
  status          QuotationStatus @default(draft)
  language        String          @default("th")
  kind            String          @default("general")
  serviceDetails  Json?

  quotationDate DateTime
  validUntil    DateTime? // วันที่สิ้นสุดราคา — หลังจากนี้ status auto → expired

  buyerId String
  seller  Json // snapshot of seller at time of issue

  subtotal       Float
  vatAmount      Float
  discountAmount Float @default(0) @map("discount")
  total          Float

  notes         String?
  paymentTerms  String? // เงื่อนไขการชำระเงิน — placeholder string ที่ขึ้นบน PDF
  deliveryTerms String? // เงื่อนไขการส่งของ

  // Conversion to Invoice
  convertedToInvoiceId String?   @map("converted_to_invoice_id")
  convertedAt          DateTime? @map("converted_at")

  // Storage
  pdfUrl String?

  // Google Drive sync (no XML — not an e-Tax doc)
  driveFileId String?
  driveUrl    String?

  // Audit
  cancelledAt  DateTime? @map("cancelled_at")
  cancelledBy  String?   @map("cancelled_by")
  cancelReason String?   @map("cancel_reason")

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company         @relation(fields: [companyId], references: [id])
  project       Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  buyer         Customer        @relation(fields: [buyerId], references: [id])
  creator       User            @relation("QuotationCreatedBy", fields: [createdBy], references: [id])
  items         QuotationItem[]
  deliveryNotes DeliveryNote[]

  @@unique([companyId, quotationNumber])
  @@index([companyId])
  @@index([companyId, projectId])
  @@index([companyId, status])
  @@index([companyId, quotationDate])
  @@index([buyerId])
  @@index([createdBy])
  @@index([convertedToInvoiceId])
  @@map("quotations")
}

model QuotationItem {
  id             String  @id @default(cuid())
  quotationId    String
  productId      String?
  sectionTitle   String? @map("section_title")
  nameTh         String
  nameEn         String?
  descriptionTh  String?
  descriptionEn  String?
  quantity       Float
  unit           String
  unitPrice      Float
  discountAmount Float   @default(0) @map("discount")
  vatType        VatType @default(vat7)
  amount         Float
  vatAmount      Float
  totalAmount    Float

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])

  @@index([quotationId])
  @@map("quotation_items")
}

// ── Delivery Note (ใบส่งของ) ─────────────────────────────────────────
// Operational delivery document. Not a tax document — no VAT obligation and
// no RD submission. Can be created standalone or from a quotation/invoice.
model DeliveryNote {
  id                 String             @id @default(cuid())
  companyId          String
  projectId          String?
  deliveryNoteNumber String
  status             DeliveryNoteStatus @default(draft)
  language           String             @default("th")

  deliveryDate DateTime
  expectedDate DateTime?
  deliveredAt  DateTime? @map("delivered_at")

  buyerId String
  seller  Json // snapshot of seller at time of issue

  // Optional source/target links
  quotationId String? @map("quotation_id")
  invoiceId   String? @map("invoice_id")

  shippingAddress String?
  contactName     String?
  contactPhone    String?
  vehicleNo       String?
  trackingNo      String?

  notes         String?
  deliveryTerms String?

  // Storage
  pdfUrl String?

  // Google Drive sync (no XML — not an e-Tax doc)
  driveFileId String?
  driveUrl    String?

  // Audit
  cancelledAt  DateTime? @map("cancelled_at")
  cancelledBy  String?   @map("cancelled_by")
  cancelReason String?   @map("cancel_reason")

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company            @relation(fields: [companyId], references: [id])
  project   Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  buyer     Customer           @relation(fields: [buyerId], references: [id])
  creator   User               @relation("DeliveryNoteCreatedBy", fields: [createdBy], references: [id])
  quotation Quotation?         @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  invoice   Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  items     DeliveryNoteItem[]

  @@unique([companyId, deliveryNoteNumber])
  @@index([companyId])
  @@index([companyId, projectId])
  @@index([companyId, status])
  @@index([companyId, deliveryDate])
  @@index([buyerId])
  @@index([createdBy])
  @@index([quotationId])
  @@index([invoiceId])
  @@map("delivery_notes")
}

