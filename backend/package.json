{
  "name": "etax-invoice-backend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts",
    "test:e2e:domains": "tsx --test src/routes/domain-split.e2e.test.ts",
    "test:integration:payments": "tsx --test src/routes/payments.integration.test.ts",
    "test:integration:invoices": "tsx --test src/routes/invoices.integration.test.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx src/database/seed.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@line/bot-sdk": "^11.0.0",
    "@prisma/client": "^5.12.1",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-forge": "^1.3.1",
    "nodemailer": "^8.0.5",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^22.7.0",
    "qrcode": "^1.5.4",
    "stripe": "^18.5.0",
    "winston": "^3.13.0",
    "xml2js": "^0.6.2",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/node-forge": "^1.3.14",
    "@types/nodemailer": "^6.4.14",
    "@types/pdf-parse": "^1.1.5",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prisma": "^5.12.1",
    "tsx": "^4.8.2",
    "typescript": "^5.4.5"
  }
}
