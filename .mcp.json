{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "tavily": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "firecrawl": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "minimax": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "my-minimax-mcp"],
      "env": {
        "MINIMAX_API_KEY": "sk-api-8tw-x7y5PDG2aSRmsLxiTeMocQ_FwC3TysjfncVJUZj1tEnzkLF4GjdR9Z1rThcc5Za19jGoEfkhnIPw3OZTqB9ywNKk3E-XzTOlW7JWFAr3E9QT436aSYE",
        "MINIMAX_DEFAULT_MODEL": "MiniMax-M2.7"
      }
    }
  }
}
