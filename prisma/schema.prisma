// Prisma schema for e-Tax Invoice System
// Bilingual support: all user-facing string fields have _th and _en variants

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  accountant
  viewer
}

enum InvoiceType {
  tax_invoice
  tax_invoice_receipt
  receipt
  credit_note
  debit_note
}

enum InvoiceStatus {
  draft
  pending
  approved
  submitted
  rejected
  cancelled
}

enum RDSubmissionStatus {
  pending
  in_progress
  success
  failed
  retrying
}

enum VatType {
  vat7
  vatExempt
  vatZero
}

enum BillingPlan {
  starter
  business
  enterprise
}

enum BillingStatus {
  pending
  active
  past_due
  canceled
  incomplete
  incomplete_expired
  trialing
  unpaid
}

enum SignupStatus {
  pending
  paid
  activated
  expired
  failed
}

enum AttachmentFileType {
  image
  pdf
  link
}

enum EvidenceType {
  receipt
  chat
  map
  other
}

enum ExpenseVoucherStatus {
  draft
  submitted
  approved
  rejected
}

enum ProjectStatus {
  active
  on_hold
  completed
  archived
}

enum ProjectMemberRole {
  owner
  approver
  member
  viewer
}

model Company {
  id           String  @id @default(cuid())
  nameTh       String
  nameEn       String?
  taxId        String  @unique
  branchCode   String  @default("00000")
  branchNameTh String?
  branchNameEn String?
  addressTh    String
  addressEn    String?
  phone        String?
  email        String?
  website      String?
  logoUrl      String?

  // Serialized certificate (encrypted)
  certificatePath     String?
  certificatePassword String?

  // RD Config
  rdClientId     String?
  rdClientSecret String?
  rdEnvironment  String  @default("sandbox")

  // Expense settings
  expenseLimit Decimal? @db.Decimal(12, 2)

  // Storage quota
  storageUsedBytes         BigInt    @default(0)
  storageQuotaBytes        BigInt    @default(524288000) // 500MB
  googleDriveOwnerUserId   String?
  googleDriveOwnerLinkedAt DateTime?

  // Company master workspace sheet (deduplicated)
  googleWorkspaceSheetId      String?
  googleWorkspaceSheetUrl     String?
  googleWorkspaceSheetSyncedAt DateTime?

  // OCR cost controls
  ocrMonthlyBudgetThb Decimal? @db.Decimal(10, 2)
  ocrUsageThisMonth   Decimal  @default(0) @db.Decimal(10, 2)

  // Line OA settings
  lineNotifyEnabled   Boolean @default(false)
  overdueReminderDays Int     @default(3)

  // Document issuing profile
  documentBankAccounts     Json?
  documentSignatureProfile Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  customers             Customer[]
  products              Product[]
  invoices              Invoice[]
  subscription          CompanySubscription?
  billingTransactions   BillingTransaction[]
  purchaseInvoices      PurchaseInvoice[]
  projectPurchaseOrders ProjectPurchaseOrder[]
  projects              Project[]
  expenseVouchers       ExpenseVoucher[]
  pettyCash             PettyCash?
  lineGroupLinks        LineGroupLink[]
  whtCertificates       WhtCertificate[]

  @@map("companies")
}

model User {
  id                  String    @id @default(cuid())
  companyId           String
  email               String    @unique
  name                String
  passwordHash        String?
  googleSub           String?   @unique
  role                UserRole  @default(viewer)
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  googleRefreshToken  String?
  googleDriveLinkedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices           Invoice[]           @relation("CreatedBy")
  auditLogs          AuditLog[]
  fcmTokens          FcmToken[]
  purchaseInvoices   PurchaseInvoice[]   @relation("PurchaseCreatedBy")
  expenseVouchers    ExpenseVoucher[]    @relation("ExpenseVoucherCreatedBy")
  ownedProjects      Project[]           @relation("ProjectOwner")
  approvedProjects   Project[]           @relation("ProjectApprover")
  createdProjects    Project[]           @relation("ProjectCreatedBy")
  projectMembers     ProjectMember[]
  lineUserLink       LineUserLink?
  lineProjectMembers LineProjectMember[]
  linkedLineGroups   LineGroupLink[]     @relation("LineGroupLinkedBy")
  driveOAuthStates   DriveOAuthState[]

  @@index([companyId])
  // List active users per company (user management page)
  @@index([companyId, isActive])
  // Role-based filtering within a tenant (e.g., list all accountants)
  @@index([companyId, role])
  @@map("users")
}

model DriveOAuthState {
  id         String   @id @default(cuid())
  state      String   @unique
  userId     String
  companyId  String
  returnPath String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
  @@map("drive_oauth_states")
}

model Customer {
  id            String  @id @default(cuid())
  companyId     String
  nameTh        String
  nameEn        String?
  taxId         String
  branchCode    String  @default("00000")
  branchNameTh  String?
  branchNameEn  String?
  addressTh     String
  addressEn     String?
  email         String?
  phone         String?
  contactPerson String?
  creditLimit   Decimal? @db.Decimal(12, 2)
  creditDays    Int?
  personalId    String? // เลขประจำตัว 13 หลักสำหรับบุคคลธรรมดา
  partyRole     String  @default("customer") // customer | supplier | both
  customerKind  String  @default("company") // company | individual
  useCase       String  @default("general") // general | full_tax_invoice | credit | contract_project | vendor_payee
  verificationStatus String @default("not_required") // not_required | missing | partial | complete
  vatEvidenceStatus  String @default("not_required") // not_required | missing | uploaded | verified
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  documents CustomerDocument[]

  @@unique([companyId, taxId, branchCode])
  @@index([companyId])
  @@index([companyId, verificationStatus])
  @@index([companyId, partyRole])
  @@index([companyId, useCase])
  // Customer list page always filters by isActive within a company
  @@index([companyId, isActive])
  @@map("customers")
}

model CustomerDocument {
  id              String   @id @default(cuid())
  companyId       String
  customerId      String
  uploadedById    String?
  documentType    String   // company_registration | vat_certificate | contract | credit_agreement | director_id | personal_id | bank_account | other
  requiredFor     String   @default("general")
  status          String   @default("uploaded") // uploaded | verified | rejected
  fileName        String
  mimeType        String
  fileSize        Int
  driveFileId     String?
  driveUrl        String?
  driveFolderId   String?
  driveFolderUrl  String?
  driveUserDrive  Boolean  @default(false)
  sensitive       Boolean  @default(false)
  notes           String?
  uploadedAt      DateTime @default(now())
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId, customerId])
  @@index([companyId, documentType])
  @@index([companyId, status])
  @@map("customer_documents")
}

model JuristicOpenDataCache {
  id           String  @id @default(cuid())
  taxId        String  @unique
  nameTh       String?
  nameEn       String?
  addressTh    String?
  status       String?
  juristicType String?
  source       String  @default("open-dbd")
  raw          Json?

  vatRegistered   Boolean   @default(false)
  vatName         String?
  vatAddress      String?
  vatSource       String?
  vatLastSyncedAt DateTime?

  lastSyncedAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([taxId])
  @@index([status])
  @@map("juristic_open_data_cache")
}

model DbdOpenDataSyncRun {
  id              String    @id @default(cuid())
  kind            String
  status          String
  source          String?
  recordsRead     Int       @default(0)
  recordsUpserted Int       @default(0)
  error           String?
  triggeredBy     String?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  @@index([kind, startedAt])
  @@index([status, startedAt])
  @@map("dbd_open_data_sync_runs")
}

model Product {
  id             String  @id @default(cuid())
  companyId      String
  code           String
  nameTh         String
  nameEn         String?
  descriptionTh  String?
  descriptionEn  String?
  unit           String
  unitPrice      Float
  vatType        VatType @default(vat7)
  productType    String  @default("product") @map("product_type")
  category       String?
  accountCode    String? @map("account_code")
  unitCost       Float?  @map("unit_cost")
  defaultWhtRate String? @map("default_wht_rate")
  internalNote   String? @map("internal_note")
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, productType])
  @@index([companyId, category])
  @@map("products")
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  projectId     String?
  invoiceNumber String
  type          InvoiceType
  status        InvoiceStatus @default(draft)
  language      String        @default("th")

  invoiceDate DateTime
  dueDate     DateTime?

  buyerId String
  seller  Json

  subtotal       Float
  vatAmount      Float
  discountAmount Float @default(0) @map("discount")
  total          Float

  // WHT (withholding tax)
  whtRate          String? @map("wht_rate")
  whtAmount        Float?  @map("wht_amount")
  whtCertificateId String? @map("wht_certificate_id")

  // Cancellation
  cancelledAt  DateTime? @map("cancelled_at")
  cancelledBy  String?   @map("cancelled_by")
  cancelReason String?   @map("cancel_reason")

  notes         String?
  paymentMethod String?

  // RD submission
  rdSubmissionStatus RDSubmissionStatus?
  rdDocId            String?
  rdSubmittedAt      DateTime?
  rdResponseXml      String?

  // Storage
  pdfUrl String?
  xmlUrl String?

  // Google Drive sync
  driveFileId    String?
  driveUrl       String?
  driveXmlFileId String?
  driveXmlUrl    String?

  // Reference (for credit/debit notes and receipts linked to a tax invoice)
  referenceDocNumber String?
  referenceInvoiceId String? // FK → Invoice (ใบอ้างอิงสำหรับ receipt/credit/debit)

  // Payment tracking
  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  paidAmount Float?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company          @relation(fields: [companyId], references: [id])
  project          Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  buyer            Customer         @relation(fields: [buyerId], references: [id])
  creator          User             @relation("CreatedBy", fields: [createdBy], references: [id])
  items            InvoiceItem[]
  referenceInvoice Invoice?         @relation("InvoiceReference", fields: [referenceInvoiceId], references: [id])
  relatedDocuments Invoice[]        @relation("InvoiceReference")
  payments         Payment[]
  whtCertificates  WhtCertificate[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, projectId])
  @@index([companyId, status])
  @@index([companyId, invoiceDate])
  // Compound index for dashboard: "issued invoices in date range" — covers status + date together
  @@index([companyId, status, invoiceDate])
  // RD submission queue filters on rdSubmissionStatus per company
  @@index([companyId, rdSubmissionStatus])
  // FK indexes — Postgres does not create these automatically
  @@index([buyerId])
  @@index([createdBy])
  @@index([referenceInvoiceId])
  @@map("invoices")
}

model InvoiceItem {
  id             String  @id @default(cuid())
  invoiceId      String
  productId      String?
  nameTh         String
  nameEn         String?
  descriptionTh  String?
  descriptionEn  String?
  quantity       Float
  unit           String
  unitPrice      Float
  discountAmount Float   @default(0) @map("discount")
  vatType        VatType @default(vat7)
  amount         Float
  vatAmount      Float
  totalAmount    Float

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model PurchaseInvoice {
  id        String  @id @default(cuid())
  companyId String
  projectId String?

  // Supplier info (snapshot at time of recording)
  supplierName   String
  supplierTaxId  String // required for VAT deduction
  supplierBranch String? @default("00000")

  // Document info
  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime?

  // Financial
  subtotal  Float // amount before VAT
  vatAmount Float @default(0) // input VAT amount (may be 0 for non-VAT)
  total     Float // subtotal + vatAmount

  // VAT classification
  vatType String @default("vat7") // vat7 | vatExempt | vatZero

  // Document details
  description String? // what was purchased
  category    String? // e.g. "office supplies", "freight", "services"
  notes       String?

  // Document storage
  pdfUrl String? // uploaded supplier invoice scan

  // Status
  isPaid Boolean   @default(false)
  paidAt DateTime?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator User     @relation("PurchaseCreatedBy", fields: [createdBy], references: [id])

  @@unique([companyId, supplierTaxId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, projectId])
  @@index([companyId, invoiceDate])
  @@index([companyId, vatType])
  @@index([createdBy])
  @@map("purchase_invoices")
}

model DocumentIntake {
  id                String    @id @default(cuid())
  companyId         String
  projectId         String?
  userId            String
  lineUserId        String?
  source            String    @default("line")
  sourceMessageId   String?
  fileName          String?
  mimeType          String
  fileSize          Int
  fileBase64        String?
  fileUrl           String?
  storageKey        String?
  driveFileId       String?
  driveUrl          String?
  driveFolderId     String?
  driveFolderUrl    String?
  driveSyncStatus   String    @default("not_synced") // not_synced | syncing | synced | failed | skipped
  driveSyncError    String?
  driveSyncedAt     DateTime?
  driveUserDrive    Boolean   @default(false)
  status            String    @default("received") // received | processing | awaiting_input | awaiting_confirmation | saved | needs_review | failed | rejected
  ocrResult         Json?
  warnings          Json?
  error             String?
  targetType        String?
  targetId          String?
  purchaseInvoiceId String?
  processedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project               Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  comments              DocumentComment[]
  projectPurchaseOrders ProjectPurchaseOrder[]

  @@index([companyId, status, createdAt])
  @@index([companyId, projectId, createdAt])
  @@index([companyId, driveSyncStatus])
  @@index([companyId, purchaseInvoiceId])
  @@index([sourceMessageId])
  @@map("document_intakes")
}

model DocumentComment {
  id               String   @id @default(cuid())
  companyId        String
  projectId        String
  documentIntakeId String
  authorType       String   @default("user") // user | guest | system
  authorUserId     String?
  authorName       String?
  kind             String   @default("comment") // comment | request | reply
  status           String   @default("open") // open | resolved
  message          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentIntake DocumentIntake @relation(fields: [documentIntakeId], references: [id], onDelete: Cascade)

  @@index([companyId, projectId, createdAt])
  @@index([companyId, documentIntakeId, createdAt])
  @@index([companyId, status])
  @@map("document_comments")
}

model AuditLog {
  id           String   @id @default(cuid())
  companyId    String
  userId       String
  action       String
  resourceType String
  resourceId   String
  details      Json
  ipAddress    String
  userAgent    String
  language     String   @default("th")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([companyId, action])
  // "All actions by this user in this company" — common admin view
  @@index([companyId, userId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model Payment {
  id                String   @id @default(cuid())
  invoiceId         String
  amount            Float
  method            String // cash, transfer, cheque, credit_card, other
  reference         String? // เลขอ้างอิงการชำระ / slip ref
  paidAt            DateTime @default(now())
  note              String?
  createdBy         String
  createdAt         DateTime @default(now())
  evidenceIntakeId  String? // DocumentIntake.id of the bank slip
  matchScore        Int?    // 0-100 match confidence for auto-matched payments
  matchedBy         String? // 'auto' | 'manual'

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([evidenceIntakeId])
  @@map("payments")
}

model OcrBenchmark {
  id           String   @id @default(cuid())
  companyId    String
  intakeId     String?
  documentType String // detected type
  provider     String // azure | typhoon | gpt4o | gemini-flash | gemini-pro | openrouter
  model        String
  costUsd      Float    @default(0)
  costThb      Float    @default(0)
  latencyMs    Int      @default(0)
  cer          Float? // computed after user confirms ground truth
  confidence   String // high | medium | low
  accepted     Boolean? // user accepted output without edit?
  stage        String // primary | verify | escalation
  createdAt    DateTime @default(now())

  @@index([companyId, documentType, provider])
  @@index([companyId, createdAt])
  @@map("ocr_benchmarks")
}

model OcrCreditLedger {
  id           String   @id @default(cuid())
  companyId    String
  intakeId     String?
  provider     String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float
  costThb      Float
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt])
  @@map("ocr_credit_ledger")
}

model DocumentTemplate {
  id        String  @id @default(cuid())
  companyId String
  type      String
  language  String
  name      String
  htmlTh    String  @db.Text
  htmlEn    String  @db.Text
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, type, language])
  @@map("document_templates")
}

model Project {
  id                  String        @id @default(cuid())
  companyId           String
  code                String
  name                String
  description         String?
  customerName        String?
  budgetAmount        Decimal       @default(0) @db.Decimal(14, 2)
  status              ProjectStatus @default(active)
  ownerId             String?
  approverId          String?
  startDate           DateTime?
  endDate             DateTime?
  metadata            Json?
  driveFolderId       String?
  driveFolderUrl      String?
  googleSheetId       String?
  googleSheetUrl      String?
  googleSheetSyncedAt DateTime?
  createdBy           String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner                 User?                  @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  approver              User?                  @relation("ProjectApprover", fields: [approverId], references: [id], onDelete: SetNull)
  creator               User                   @relation("ProjectCreatedBy", fields: [createdBy], references: [id])
  members               ProjectMember[]
  invoices              Invoice[]
  purchaseInvoices      PurchaseInvoice[]
  projectPurchaseOrders ProjectPurchaseOrder[]
  documentIntakes       DocumentIntake[]
  documentComments      DocumentComment[]
  expenseVouchers       ExpenseVoucher[]
  lineGroupLinks        LineGroupLink[]
  lineProjectMembers    LineProjectMember[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([companyId, ownerId])
  @@index([companyId, approverId])
  @@index([createdBy])
  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(member)
  createdAt DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
  @@map("project_members")
}

model ProjectPurchaseOrder {
  id               String    @id @default(cuid())
  companyId        String
  projectId        String
  documentIntakeId String?
  poNumber         String
  documentType     String    @default("purchase_order")
  vendorName       String?
  vendorTaxId      String?
  issueDate        DateTime?
  expectedDate     DateTime?
  subtotal         Float?
  vatAmount        Float?
  total            Float?
  currency         String    @default("THB")
  status           String    @default("open")
  source           String    @default("document_intake")
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentIntake DocumentIntake? @relation(fields: [documentIntakeId], references: [id], onDelete: SetNull)

  @@unique([companyId, projectId, poNumber])
  @@index([companyId, projectId, issueDate])
  @@index([companyId, projectId, status])
  @@index([companyId, documentIntakeId])
  @@map("project_purchase_orders")
}

model CompanySubscription {
  id                      String        @id @default(cuid())
  companyId               String        @unique
  plan                    BillingPlan
  status                  BillingStatus @default(pending)
  billingInterval         String        @default("month")
  docLimit                Int?
  stripeCustomerId        String?       @unique
  stripeSubscriptionId    String?       @unique
  stripePriceId           String?
  stripeCheckoutSessionId String?       @unique
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean       @default(false)
  activatedAt             DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
  @@map("company_subscriptions")
}

model Coupon {
  id                    String    @id @default(cuid())
  code                  String    @unique
  name                  String
  description           String?
  discountType          String
  discountValue         Float
  minSubtotalAmount     Float?
  maxDiscountAmount     Float?
  maxRedemptions        Int?
  redeemedCount         Int       @default(0)
  stripePromotionCodeId String?   @unique
  active                Boolean   @default(true)
  startsAt              DateTime?
  endsAt                DateTime?
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  transactions BillingTransaction[]

  @@index([active])
  @@index([startsAt, endsAt])
  @@map("coupons")
}

model BillingTransaction {
  id                String      @id @default(cuid())
  companyId         String?
  pendingSignupId   String?
  couponId          String?
  plan              BillingPlan
  channel           String
  status            String      @default("pending")
  currency          String      @default("THB")
  subtotalAmount    Float
  discountAmount    Float       @default(0)
  totalAmount       Float
  couponCode        String?
  externalReference String?
  qrPayload         String?     @db.Text
  qrImageDataUrl    String?     @db.Text
  paidAt            DateTime?
  metadata          Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  pendingSignup PendingSignup? @relation(fields: [pendingSignupId], references: [id], onDelete: SetNull)
  coupon        Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([pendingSignupId])
  @@index([couponId])
  @@index([channel, status])
  @@index([plan, createdAt])
  @@index([createdAt])
  @@map("billing_transactions")
}

model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String // "android" | "ios" | "web"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model PendingSignup {
  id                      String       @id @default(cuid())
  companyNameTh           String
  companyNameEn           String?
  taxId                   String
  addressTh               String
  adminName               String
  adminEmail              String
  phone                   String?
  plan                    BillingPlan
  paymentMethod           String       @default("stripe")
  couponCode              String?
  subtotalAmount          Float?
  discountAmount          Float        @default(0)
  totalAmount             Float?
  status                  SignupStatus @default(pending)
  locale                  String       @default("th")
  stripeCheckoutSessionId String?      @unique
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  stripePriceId           String?
  companyId               String?
  userId                  String?
  activatedAt             DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  transactions BillingTransaction[]

  @@index([adminEmail])
  @@index([status])
  @@index([plan])
  @@map("pending_signups")
}

model LineOtp {
  id        String   @id @default(cuid())
  otp       String   @unique
  type      String   @default("user")
  userId    String?
  companyId String
  projectId String?
  issuedBy  String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([companyId, projectId])
  @@map("line_otps")
}

model LineUserLink {
  id          String   @id @default(cuid())
  userId      String   @unique
  lineUserId  String   @unique
  displayName String?
  pictureUrl  String?
  isActive    Boolean  @default(true)
  linkedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lineUserId])
  @@map("line_user_links")
}

model LineGroupLink {
  id                    String    @id @default(cuid())
  companyId             String
  projectId             String?
  lineGroupId           String    @unique
  sourceType            String    @default("group")
  groupName             String?
  pictureUrl            String?
  memberCount           Int?
  lastMessageAt         DateTime?
  lastSenderLineUserId  String?
  lastSenderDisplayName String?
  lastSyncedAt          DateTime?
  isActive              Boolean   @default(true)
  linkedById            String?
  linkedAt              DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project  Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  linkedBy User?               @relation("LineGroupLinkedBy", fields: [linkedById], references: [id], onDelete: SetNull)
  members  LineProjectMember[]

  @@index([companyId])
  @@index([companyId, projectId])
  @@index([companyId, isActive])
  @@index([lineGroupId])
  @@map("line_group_links")
}

model LineProjectMember {
  id              String   @id @default(cuid())
  companyId       String
  projectId       String
  lineGroupLinkId String
  lineUserId      String
  displayName     String?
  pictureUrl      String?
  linkedUserId    String?
  role            String   @default("line_guest")
  documentCount   Int      @default(0)
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineGroupLink LineGroupLink @relation(fields: [lineGroupLinkId], references: [id], onDelete: Cascade)
  linkedUser    User?         @relation(fields: [linkedUserId], references: [id], onDelete: SetNull)

  @@unique([lineGroupLinkId, lineUserId])
  @@index([companyId, projectId])
  @@index([companyId, lineUserId])
  @@index([projectId, role])
  @@map("line_project_members")
}

model ExpenseVoucher {
  id            String               @id @default(cuid())
  companyId     String
  projectId     String?
  voucherNumber String
  status        ExpenseVoucherStatus @default(draft)
  voucherDate   DateTime
  description   String?
  notes         String?
  metadata      Json?

  totalAmount Decimal @default(0) @db.Decimal(12, 2)

  submittedBy   String?
  submittedAt   DateTime?
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectionNote String?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator      User          @relation("ExpenseVoucherCreatedBy", fields: [createdBy], references: [id])
  items        ExpenseItem[]
  approvalLogs ApprovalLog[]

  @@unique([companyId, voucherNumber])
  @@index([companyId])
  @@index([companyId, projectId])
  @@index([companyId, status])
  @@index([companyId, voucherDate])
  @@index([createdBy])
  @@map("expense_vouchers")
}

model ApprovalLog {
  id        String               @id @default(cuid())
  expenseId String
  action    ExpenseVoucherStatus
  byUserId  String
  note      String?
  timestamp DateTime             @default(now())

  expense ExpenseVoucher @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@map("approval_logs")
}

model ExpenseItem {
  id          String   @id @default(cuid())
  voucherId   String
  description String
  category    String?
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  notes       String?
  metadata    Json?

  // Vendor info
  vendorName  String?
  vendorTaxId String?

  // WHT
  whtApplicable Boolean  @default(false)
  whtRate       Decimal? @db.Decimal(5, 2)
  whtAmount     Decimal? @db.Decimal(12, 2)
  netAmount     Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  voucher     ExpenseVoucher      @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  attachments ExpenseAttachment[]

  @@index([voucherId])
  @@map("expense_items")
}

model PettyCash {
  id        String  @id @default(cuid())
  companyId String  @unique
  cashierId String?
  balance   Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // cashierId is a soft reference — no Prisma relation to avoid one-to-one constraint issues

  @@map("petty_cash")
}

model ExpenseAttachment {
  id            String             @id @default(cuid())
  expenseItemId String
  fileName      String?
  fileType      AttachmentFileType @default(image)
  url           String
  evidenceType  EvidenceType       @default(receipt)

  createdAt DateTime @default(now())

  expenseItem ExpenseItem @relation(fields: [expenseItemId], references: [id], onDelete: Cascade)

  @@index([expenseItemId])
  @@map("expense_attachments")
}

model WhtCertificate {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  invoiceId         String?  @map("invoice_id")
  certificateNumber String   @map("certificate_number")
  whtRate           String   @map("wht_rate")
  whtAmount         Float    @map("wht_amount")
  totalAmount       Float    @map("total_amount")
  netAmount         Float    @map("net_amount")
  recipientName     String   @map("recipient_name")
  recipientTaxId    String   @map("recipient_tax_id")
  recipientBranch   String   @default("00000") @map("recipient_branch")
  incomeType        String?  @map("income_type")
  paymentDate       DateTime @map("payment_date")
  pdfUrl            String?  @map("pdf_url")
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@unique([companyId, certificateNumber])
  @@index([companyId])
  @@index([companyId, paymentDate])
  @@map("wht_certificates")
}
