// Prisma schema for e-Tax Invoice System
// Bilingual support: all user-facing string fields have _th and _en variants

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  accountant
  viewer
}

enum InvoiceType {
  tax_invoice
  tax_invoice_receipt
  receipt
  credit_note
  debit_note
}

enum InvoiceStatus {
  draft
  pending
  approved
  submitted
  rejected
  cancelled
}

enum RDSubmissionStatus {
  pending
  in_progress
  success
  failed
  retrying
}

enum VatType {
  vat7
  vatExempt
  vatZero
}

enum BillingPlan {
  starter
  business
  enterprise
}

enum BillingStatus {
  pending
  active
  past_due
  canceled
  incomplete
  incomplete_expired
  trialing
  unpaid
}

enum SignupStatus {
  pending
  paid
  activated
  expired
  failed
}

enum ExpenseVoucherStatus {
  draft
  submitted
  approved
  rejected
}

model Company {
  id            String  @id @default(cuid())
  nameTh        String
  nameEn        String?
  taxId         String  @unique
  branchCode    String  @default("00000")
  branchNameTh  String?
  branchNameEn  String?
  addressTh     String
  addressEn     String?
  phone         String?
  email         String?
  website       String?
  logoUrl       String?

  // Serialized certificate (encrypted)
  certificatePath     String?
  certificatePassword String?

  // RD Config
  rdClientId     String?
  rdClientSecret String?
  rdEnvironment  String  @default("sandbox")

  // Expense settings
  expenseLimit        Decimal?  @db.Decimal(12, 2)

  // Line OA settings
  lineNotifyEnabled   Boolean @default(false)
  overdueReminderDays Int     @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  customers Customer[]
  products  Product[]
  invoices  Invoice[]
  subscription CompanySubscription?
  billingTransactions BillingTransaction[]
  purchaseInvoices    PurchaseInvoice[]
  expenseVouchers     ExpenseVoucher[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String   @unique
  name         String
  passwordHash String?
  googleSub    String?  @unique
  role         UserRole @default(viewer)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices         Invoice[]         @relation("CreatedBy")
  auditLogs        AuditLog[]
  fcmTokens        FcmToken[]
  purchaseInvoices PurchaseInvoice[] @relation("PurchaseCreatedBy")
  expenseVouchers  ExpenseVoucher[]  @relation("ExpenseVoucherCreatedBy")
  lineUserLink     LineUserLink?

  @@index([companyId])
  // List active users per company (user management page)
  @@index([companyId, isActive])
  // Role-based filtering within a tenant (e.g., list all accountants)
  @@index([companyId, role])
  @@map("users")
}

model Customer {
  id            String  @id @default(cuid())
  companyId     String
  nameTh        String
  nameEn        String?
  taxId         String
  branchCode    String  @default("00000")
  branchNameTh  String?
  branchNameEn  String?
  addressTh     String
  addressEn     String?
  email         String?
  phone         String?
  contactPerson String?
  personalId    String?  // เลขบัตรประชาชน 13 หลัก (สำหรับ Easy e-Receipt)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@unique([companyId, taxId, branchCode])
  @@index([companyId])
  // Customer list page always filters by isActive within a company
  @@index([companyId, isActive])
  @@map("customers")
}

model Product {
  id            String  @id @default(cuid())
  companyId     String
  code          String
  nameTh        String
  nameEn        String?
  descriptionTh String?
  descriptionEn String?
  unit          String
  unitPrice     Float
  vatType       VatType @default(vat7)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("products")
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  invoiceNumber String
  type          InvoiceType
  status        InvoiceStatus @default(draft)
  language      String        @default("th")

  invoiceDate DateTime
  dueDate     DateTime?

  buyerId String
  seller  Json

  subtotal  Float
  vatAmount Float
  discount  Float @default(0)
  total     Float

  notes         String?
  paymentMethod String?

  // RD submission
  rdSubmissionStatus RDSubmissionStatus?
  rdDocId            String?
  rdSubmittedAt      DateTime?
  rdResponseXml      String?

  // Storage
  pdfUrl String?
  xmlUrl String?

  // Reference (for credit/debit notes and receipts linked to a tax invoice)
  referenceDocNumber  String?
  referenceInvoiceId  String?   // FK → Invoice (ใบอ้างอิงสำหรับ receipt/credit/debit)

  // Payment tracking
  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  paidAmount Float?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company       @relation(fields: [companyId], references: [id])
  buyer            Customer      @relation(fields: [buyerId], references: [id])
  creator          User          @relation("CreatedBy", fields: [createdBy], references: [id])
  items            InvoiceItem[]
  referenceInvoice Invoice?      @relation("InvoiceReference", fields: [referenceInvoiceId], references: [id])
  relatedDocuments Invoice[]     @relation("InvoiceReference")
  payments         Payment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, invoiceDate])
  // Compound index for dashboard: "issued invoices in date range" — covers status + date together
  @@index([companyId, status, invoiceDate])
  // RD submission queue filters on rdSubmissionStatus per company
  @@index([companyId, rdSubmissionStatus])
  // FK indexes — Postgres does not create these automatically
  @@index([buyerId])
  @@index([createdBy])
  @@index([referenceInvoiceId])
  @@map("invoices")
}

model InvoiceItem {
  id            String  @id @default(cuid())
  invoiceId     String
  productId     String?
  nameTh        String
  nameEn        String?
  descriptionTh String?
  descriptionEn String?
  quantity      Float
  unit          String
  unitPrice     Float
  discount      Float   @default(0)
  vatType       VatType @default(vat7)
  amount        Float
  vatAmount     Float
  totalAmount   Float

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model PurchaseInvoice {
  id          String   @id @default(cuid())
  companyId   String

  // Supplier info (snapshot at time of recording)
  supplierName   String
  supplierTaxId  String            // required for VAT deduction
  supplierBranch String?  @default("00000")

  // Document info
  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime?

  // Financial
  subtotal  Float                  // amount before VAT
  vatAmount Float   @default(0)    // input VAT amount (may be 0 for non-VAT)
  total     Float                  // subtotal + vatAmount

  // VAT classification
  vatType   String  @default("vat7")  // vat7 | vatExempt | vatZero

  // Document details
  description  String?   // what was purchased
  category     String?   // e.g. "office supplies", "freight", "services"
  notes        String?

  // Document storage
  pdfUrl    String?   // uploaded supplier invoice scan

  // Status
  isPaid    Boolean  @default(false)
  paidAt    DateTime?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id])
  creator   User     @relation("PurchaseCreatedBy", fields: [createdBy], references: [id])

  @@unique([companyId, supplierTaxId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, invoiceDate])
  @@index([companyId, vatType])
  @@index([createdBy])
  @@map("purchase_invoices")
}

model DocumentIntake {
  id                String    @id @default(cuid())
  companyId         String
  userId            String
  lineUserId        String?
  source            String    @default("line")
  sourceMessageId   String?
  fileName          String?
  mimeType          String
  fileSize          Int
  fileBase64        String?
  fileUrl           String?
  storageKey        String?
  status            String    @default("received") // received | processing | awaiting_input | awaiting_confirmation | saved | needs_review | failed | rejected
  ocrResult         Json?
  warnings          Json?
  error             String?
  targetType        String?
  targetId          String?
  purchaseInvoiceId String?
  processedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId, status, createdAt])
  @@index([companyId, purchaseInvoiceId])
  @@index([sourceMessageId])
  @@map("document_intakes")
}

model AuditLog {
  id           String   @id @default(cuid())
  companyId    String
  userId       String
  action       String
  resourceType String
  resourceId   String
  details      Json
  ipAddress    String
  userAgent    String
  language     String   @default("th")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([companyId, action])
  // "All actions by this user in this company" — common admin view
  @@index([companyId, userId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model Payment {
  id            String   @id @default(cuid())
  invoiceId     String
  amount        Float
  method        String   // cash, transfer, cheque, credit_card, other
  reference     String?  // เลขอ้างอิงการชำระ / slip ref
  paidAt        DateTime @default(now())
  note          String?
  createdBy     String
  createdAt     DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model DocumentTemplate {
  id       String @id @default(cuid())
  companyId String
  type     String
  language String
  name     String
  htmlTh   String @db.Text
  htmlEn   String @db.Text
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, type, language])
  @@map("document_templates")
}

model CompanySubscription {
  id                    String        @id @default(cuid())
  companyId             String        @unique
  plan                  BillingPlan
  status                BillingStatus @default(pending)
  billingInterval       String        @default("month")
  docLimit              Int?
  stripeCustomerId      String?       @unique
  stripeSubscriptionId  String?       @unique
  stripePriceId         String?
  stripeCheckoutSessionId String?     @unique
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean       @default(false)
  activatedAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
  @@map("company_subscriptions")
}

model Coupon {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  description        String?
  discountType       String
  discountValue      Float
  minSubtotalAmount  Float?
  maxDiscountAmount  Float?
  maxRedemptions     Int?
  redeemedCount      Int      @default(0)
  stripePromotionCodeId String? @unique
  active             Boolean  @default(true)
  startsAt           DateTime?
  endsAt             DateTime?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions BillingTransaction[]

  @@index([active])
  @@index([startsAt, endsAt])
  @@map("coupons")
}

model BillingTransaction {
  id                String      @id @default(cuid())
  companyId         String?
  pendingSignupId   String?
  couponId          String?
  plan              BillingPlan
  channel           String
  status            String      @default("pending")
  currency          String      @default("THB")
  subtotalAmount    Float
  discountAmount    Float       @default(0)
  totalAmount       Float
  couponCode        String?
  externalReference String?
  qrPayload         String?     @db.Text
  qrImageDataUrl    String?     @db.Text
  paidAt            DateTime?
  metadata          Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  pendingSignup PendingSignup? @relation(fields: [pendingSignupId], references: [id], onDelete: SetNull)
  coupon        Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([pendingSignupId])
  @@index([couponId])
  @@index([channel, status])
  @@index([plan, createdAt])
  @@index([createdAt])
  @@map("billing_transactions")
}

model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // "android" | "ios" | "web"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model PendingSignup {
  id                     String       @id @default(cuid())
  companyNameTh          String
  companyNameEn          String?
  taxId                  String
  addressTh              String
  adminName              String
  adminEmail             String
  phone                  String?
  plan                   BillingPlan
  paymentMethod          String       @default("stripe")
  couponCode             String?
  subtotalAmount         Float?
  discountAmount         Float        @default(0)
  totalAmount            Float?
  status                 SignupStatus @default(pending)
  locale                 String       @default("th")
  stripeCheckoutSessionId String?     @unique
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripePriceId          String?
  companyId              String?
  userId                 String?
  activatedAt            DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  transactions BillingTransaction[]

  @@index([adminEmail])
  @@index([status])
  @@index([plan])
  @@map("pending_signups")
}

model LineUserLink {
  id          String   @id @default(cuid())
  userId      String   @unique
  lineUserId  String   @unique
  displayName String?
  pictureUrl  String?
  isActive    Boolean  @default(true)
  linkedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lineUserId])
  @@map("line_user_links")
}

model ExpenseVoucher {
  id            String               @id @default(cuid())
  companyId     String
  voucherNumber String
  status        ExpenseVoucherStatus @default(draft)
  voucherDate   DateTime
  description   String?
  notes         String?
  metadata      Json?

  totalAmount   Decimal              @default(0) @db.Decimal(12, 2)

  submittedBy   String?
  submittedAt   DateTime?
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectionNote String?

  createdBy     String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator       User                 @relation("ExpenseVoucherCreatedBy", fields: [createdBy], references: [id])
  items         ExpenseItem[]

  @@unique([companyId, voucherNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, voucherDate])
  @@index([createdBy])
  @@map("expense_vouchers")
}

model ExpenseItem {
  id            String         @id @default(cuid())
  voucherId     String
  description   String
  category      String?
  amount        Decimal        @db.Decimal(12, 2)
  date          DateTime
  notes         String?
  metadata      Json?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  voucher       ExpenseVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  attachments   ExpenseAttachment[]

  @@index([voucherId])
  @@map("expense_items")
}

model ExpenseAttachment {
  id            String       @id @default(cuid())
  expenseItemId String
  fileName      String?
  mimeType      String
  fileSize      Int
  fileBase64    String?
  fileUrl       String?
  storageKey    String?

  createdAt     DateTime     @default(now())

  expenseItem   ExpenseItem  @relation(fields: [expenseItemId], references: [id], onDelete: Cascade)

  @@index([expenseItemId])
  @@map("expense_attachments")
}
