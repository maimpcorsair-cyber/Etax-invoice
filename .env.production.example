# Production database / cache
DATABASE_URL="postgresql://USER:PASSWORD@db.example.com:5432/etax_invoice"
REDIS_URL="redis://:PASSWORD@redis.example.com:6379"

# Database connection pool
DB_POOL_SIZE=20

# Transaction timeout in milliseconds
DB_TX_TIMEOUT=60000

# Rate limiting (Redis-based sliding window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# App security
NODE_ENV="production"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Canonical frontend origins
APP_ORIGIN="https://app.example.com"
OPS_ORIGIN="https://ops.example.com"
FRONTEND_URLS="https://app.example.com,https://ops.example.com"

# Frontend build-time origins
VITE_APP_ORIGIN="https://app.example.com"
VITE_OPS_ORIGIN="https://ops.example.com"

# Google Sign-In
GOOGLE_CLIENT_ID="your-google-web-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-web-client-secret"

# Google Drive / Sheets
# OAuth redirect must also be added in Google Cloud Console authorized redirect URIs.
GOOGLE_DRIVE_REDIRECT_URI="https://api.example.com/api/drive/callback"
# Use one service-account JSON env for project folders/sheets when users have not linked personal Drive.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'
# Alternative to JSON env: GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# Stripe Billing
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_BUSINESS_MONTHLY="price_..."

# Optional storage / RD / mail settings follow your deployment environment
