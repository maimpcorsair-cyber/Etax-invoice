{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend API (Express + tsx watch)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "backend",
      "port": 4000,
      "autoPort": false
